APP_NAME=AI SQL Analytics Agent
APP_VERSION=1.0.0
APP_ENV=development
APP_PORT=8000

SECRET_KEY=change-me

# Database (used by both the app and the docker-compose MySQL service)
DB_HOST=db
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=apppass
DB_NAME=sql_analytics
DB_ROOT_PASSWORD=rootpass
DATABASE_URL=mysql+pymysql://appuser:apppass@db:3306/sql_analytics

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LOG_LEVEL=INFO
LOG_FILE=logs/app.log

MAX_QUERY_ROWS=1000
QUERY_TIMEOUT=30


DATABASE_SECRET_KEY=

# Redis (used by both the app and the docker-compose Redis service)
# Use `redis` when running via docker-compose, `localhost` for local dev.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=600
